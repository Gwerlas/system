# Ansible managed, do not edit

sys-kernel/*-sources   symlink

# required by sys-kernel/gentoo-kernel-bin-6.6.13::gentoo[initramfs]
# required by virtual/dist-kernel-6.6.13::gentoo
>=sys-kernel/installkernel-24 dracut

{% if system_portage_kernel is search('-kernel') %}
*/* dist-kernel

# savedconfig: build from the role-seeded config in
# /etc/portage/savedconfig/sys-kernel/ (see docs/packages.md "Kernel").
# -debug: the amd64 profile enables USE=debug on dist-kernels (>=6.6.53),
# keeping full DWARF debuginfo on every module — tens of GB in PORTAGE_TMPDIR
# for debuginfo we don't ship.
sys-kernel/{{ system_portage_kernel }} savedconfig -debug
{% endif %}
